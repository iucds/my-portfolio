---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { Image } from 'astro:assets';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="timeline-wrapper">
				<h2 class="section-title">My Academic Journey and Experience</h2>
				
				<div class="timeline-container">
					<div class="scroll-line"></div>

					<div class="timeline-item" data-timeline>
						<div class="circle"></div>
						<div class="content-card">
							<h3>Greenwood Primary School</h3>
							<p class="qualification">PSLE</p>
							<p class="duration">2013-2018</p>
							<div class="details">
								<p>
									<b>T-Score</b>: 245 <br>
									<b>Co-Curricular Activities</b>: Rugby
								</p>
							</div>
						</div>
					</div>

					<div class="timeline-item" data-timeline>
						<div class="circle"></div>
						<div class="content-card">
							<h3>School of Science and Technology, Singapore</h3>
							<p class="qualification">GCE O Level</p>
							<p class="duration">2019 — 2022</p>
							<div class="details">
								<p>
									<b>L1R5</b>: 7-2 <br>
									<b>E1R2B2-C</b>: 5-2 <br>
									<b>Subjects</b>: <br>
									English, Elementary Mathematics, Additional Mathematics, Physics, Chemistry, Electronics, Combined Humanities (Social Studies/History) <br>
									<b>Co-Curricular Activities</b>: <br>
									<ul id="bullet-list">
										<li>Athletics (Track) (2019-2022)</li>
										<li>Science Talent Development Programme (2019-2022)</li>
									</ul>
									
									<b>Leadership (Active Citizenship Education Leadership Board)</b>:  <br>
									<ul id="bullet-list">
										<li>Junior ACE Leader (2020-2021) </li>
										<li>Senior ACE Leader (2021-2022) </li>
									</ul>
								</p>
							</div>
						</div>
					</div>

					<div class="timeline-item" data-timeline>
						<div class="circle"></div>
						<div class="content-card">
							<h3>Ngee Ann Polytechnic</h3>
							<p class="qualification">Diploma in Engineering Science</p>
							<p class="duration">2023 — Present</p>
							<div class="details">
								<p>
									<b>Cummulative GPA</b>: 4.0 <br>
									<b>Diploma Plus</b>: Certificate in Advanced Engineering Mathematics (CAEM)<br> 
									<b>Minors</b>: 
									<ul id="bullet-list">
										<li>Cybersecurity</li>
										<li>Social Leadership</li>
										<li>Global Readiness</li>
									</ul>
									<b>Co-Curricular Activities</b>:
									<ul id="bullet-list">
										<li>Engineering Science Academic Club (2023-2025)</li>
										<li>Engineering Interest Group (2023-2025)</li>
										<li>Rock Climbing (2023-2025)</li>
										<li>Judo (2025-2026)</li>
									</ul>
									<b>Leadership</b>:
										<ul id="bullet-list">
										<li>Chairperson for Wings of Solidarity (2024)</li>
										<li>Head of Logistics for Engineering Science Academic Club (2024-2025)</li>
										<li>Student Leader for Youth Expedition Project to Udon Thani, Thailand (2025)</li>
									</ul>
								</p>
							</div>
						</div>
					</div>
					<div class="timeline-item" data-timeline>
						<div class="circle"></div>
						<div class="content-card">
							<h3>National University of Singapore (NUS)</h3>
							<p class="qualification">Final Year Project</p>
							<p class="duration">2025-2026</p>
							<div class="details">
								<p>
									Worked in the Center for Ion Beam Analysis (CIBA) to develop a data acquisition device for use in experimental physics.
								</p>
							</div>
						</div>
					</div>
					<div class="timeline-item" data-timeline>
						<div class="circle"></div>
						<div class="content-card">
							<h3>Singapore Institute of Manufacturing Technology (SIMTech)</h3>
							<p class="qualification">Research Intern</p>
							<p class="duration">2026-Present</p>
							<div class="details">
								<p>
									Working in the Adaptive Robotics and Mechatronics (ARM) department in firmware development and implementation of embedded solutions for robotics.
								</p>
							</div>
						</div>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>


<style>
	.timeline-wrapper {
		max-width: 1000px; /* Matches your Hero section width */
	}

	.section-title {
		text-align: center;
		color: #0056b3;
		margin-bottom: 4rem;
	}

	.timeline-container {
		position: relative;
		padding-left: 50px; /* Space for the vertical line */
	}

	/* Background line track */
	.scroll-line {
		position: absolute;
		left: 20px;
		top: 0;
		width: 4px;
		height: 100%;
		background: #eee;
		z-index: 0;
	}

	/* Active blue line that grows on scroll */
	.scroll-line::after {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: var(--scroll-height, 0%);
		background: #0056b3;
		transition: height 0.3s ease-out;
	}

	.timeline-item {
		position: relative;
		margin-bottom: 5rem;
		opacity: 0;
		transform: translateX(-20px);
		transition: all 0.6s ease-out;
	}

	.timeline-item.is-visible {
		opacity: 1;
		transform: translateX(0);
	}

	.circle {
    position: absolute;
    left: -42px; 
    top: 25px; /* Adjust this to align with the first line of your text */
    
    width: 20px;
    height: 20px;
    background: white;
    border: 4px solid #0056b3;
    border-radius: 50%;
    z-index: 2;
    transition: all 0.4s ease;
  }

  /* Optional: Make the circle slightly larger when the section is active */
  .timeline-item.is-visible .circle {
    background: #0056b3;
    transform: scale(1.2);
  }

	.content-card {
		background: white;
		padding: 2.5rem;
		border-radius: 12px;
		box-shadow: 0 10px 25px rgba(0,0,0,0.05); /* Soft shadow */
		border-top: 4px solid #0056b3;           /* Top accent line */
		text-align: left;                     /* Consistent with About page */
		line-height: 1.6;
	}

	.qualification {
		font-weight: bold;
		margin: 0;
		color: #333;
	}

	.duration {
		font-style: italic;
		color: #666;
		margin-bottom: 1rem;
	}

	.timeline-btn {
		display: inline-block;
		margin-top: 1.5rem;
		padding: 0.6rem 1.2rem;
		background: #0056b3;
		color: white;
		text-decoration: none;
		border-radius: 4px;
		font-size: 0.9rem;
		transition: background 0.2s;
	}

	.timeline-btn:hover {
		background: #004494;
	}
</style>

<script>
	const timelineItems = document.querySelectorAll('[data-timeline]');
	const container = document.querySelector('.timeline-container');

	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				entry.target.classList.add('is-visible');
			}
		});
	}, { threshold: 0.2 });

	timelineItems.forEach(item => observer.observe(item));

	window.addEventListener('scroll', () => {
		if (!container) return;
		const rect = container.getBoundingClientRect();
		const windowHeight = window.innerHeight;
		
		// Calculate percentage relative to the timeline section
		let percentage = (windowHeight / 1.5 - rect.top) / rect.height * 100;
		percentage = Math.min(Math.max(percentage, 0), 100);
		
		container.style.setProperty('--scroll-height', `${percentage}%`);
	});
</script>
