---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { Image } from 'astro:assets';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Academic Journey | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="timeline-wrapper">
				<h2 class="section-title">My Academic Journey and Experience</h2>
				
				<div class="timeline-container">
					<div class="scroll-line"></div>

					<div class="timeline-item" data-timeline>
						<div class="circle"></div>
						<div class="content-card">
							<h3>Greenwood Primary School</h3>
							<p class="qualification">PSLE</p>
							<p class="duration">2013-2018</p>
							<div class="details">
								<p>
									<b>T-Score</b>: 245 <br>
									<b>Co-Curricular Activities</b>: Rugby
								</p>
							</div>
						</div>
					</div>

					<div class="timeline-item" data-timeline>
						<div class="circle"></div>
						<div class="content-card">
							<h3>School of Science and Technology, Singapore</h3>
							<p class="qualification">GCE O Level</p>
							<p class="duration">2019 — 2022</p>
							<div class="details">
								<p>
									<b>L1R5</b>: 7-2 | <b>E1R2B2-C</b>: 5-2 <br>
									<b>Subjects</b>: English, E-Math, A-Math, Physics, Chemistry, Electronics, Humanities <br>
									<b>Leadership</b>: Senior ACE Leader (2021-2022)
								</p>
							</div>
						</div>
					</div>

					<div class="timeline-item" data-timeline>
						<div class="circle"></div>
						<div class="content-card">
							<h3>Ngee Ann Polytechnic</h3>
							<p class="qualification">Diploma in Engineering Science</p>
							<p class="duration">2023 — Present</p>
							<div class="details">
								<p>
									<b>Cumulative GPA</b>: 4.0 <br>
									<b>Diploma Plus</b>: Certificate in Advanced Engineering Mathematics (CAEM)<br>
									<b>Leadership</b>: Chairperson for Wings of Solidarity (2024)
								</p>
							</div>
						</div>
					</div>

					<div class="timeline-item" data-timeline>
						<div class="circle"></div>
						<div class="content-card">
							<h3>National University of Singapore (NUS)</h3>
							<p class="qualification">Final Year Project (CIBA)</p>
							<p class="duration">2025-2026</p>
							<div class="details">
								<p>
									Developed a high-speed data acquisition device for experimental physics using the **RP2350**.
								</p>
							</div>
						</div>
					</div>

					<div class="timeline-item" data-timeline>
						<div class="circle"></div>
						<div class="content-card">
							<h3>SIMTech (A*STAR)</h3>
							<p class="qualification">Research Intern (Adaptive Robotics)</p>
							<p class="duration">2026-Present</p>
							<div class="details">
								<p>
									Firmware development and embedded solutions for high-performance robotics.
								</p>
							</div>
						</div>
					</div>
				</div>
			</section>
		</main>
		<Footer />

		<script>
			const timelineItems = document.querySelectorAll('[data-timeline]');
			const container = document.querySelector('.timeline-container');

			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						entry.target.classList.add('is-visible');
					}
				});
			}, { threshold: 0.2 });

			timelineItems.forEach(item => observer.observe(item));

			window.addEventListener('scroll', () => {
				if (!container) return;
				const rect = container.getBoundingClientRect();
				const windowHeight = window.innerHeight;
				
				let percentage = (windowHeight / 1.5 - rect.top) / rect.height * 100;
				percentage = Math.min(Math.max(percentage, 0), 100);
				
				(container as HTMLElement).style.setProperty('--scroll-height', `${percentage}%`);
			});
		</script>
	</body>
</html>

<style>
	/* --- THE GAP FIX --- */
	main {
		margin-top: 80px; /* Aligns content below your fixed header */
		width: 100%;
	}

	.timeline-wrapper {
		max-width: 1000px;
		margin: 0 auto;
		padding: 2rem; /* Side padding for mobile breathing room */
	}

	.section-title {
		text-align: center;
		color: #0056b3;
		margin-bottom: 4rem;
		font-size: 2.2rem;
	}

	.timeline-container {
		position: relative;
		padding-left: 50px;
	}

	/* Background line track */
	.scroll-line {
		position: absolute;
		left: 20px;
		top: 0;
		width: 4px;
		height: 100%;
		background: #eee;
		z-index: 0;
	}

	/* Active blue line that grows on scroll */
	.scroll-line::after {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: var(--scroll-height, 0%);
		background: #0056b3;
		transition: height 0.3s ease-out;
	}

	.timeline-item {
		position: relative;
		margin-bottom: 5rem;
		opacity: 0;
		transform: translateX(-20px);
		transition: all 0.6s ease-out;
	}

	.timeline-item.is-visible {
		opacity: 1;
		transform: translateX(0);
	}

	.circle {
		position: absolute;
		left: -42px; 
		top: 25px;
		width: 20px;
		height: 20px;
		background: white;
		border: 4px solid #0056b3;
		border-radius: 50%;
		z-index: 2;
		transition: all 0.4s ease;
	}

	.timeline-item.is-visible .circle {
		background: #0056b3;
		transform: scale(1.2);
	}

	.content-card {
		background: white;
		padding: 2.5rem;
		border-radius: 12px;
		box-shadow: 0 10px 25px rgba(0,0,0,0.05);
		border-top: 4px solid #0056b3; 
		text-align: left;
		line-height: 1.6;
	}

	.qualification { font-weight: bold; color: #333; margin: 0; }
	.duration { font-style: italic; color: #666; margin-bottom: 1rem; }

	/* Bullet List Consistency */
	#bullet-list {
		padding-left: 1.2rem;
		margin: 0.5rem 0;
	}

	@media (max-width: 768px) {
		.timeline-wrapper { padding: 1rem; }
		.section-title { font-size: 1.8rem; margin-bottom: 2rem; }
		.content-card { padding: 1.5rem; }
		.timeline-container { padding-left: 35px; }
		.circle { left: -27px; width: 16px; height: 16px; }
		.scroll-line { left: 15px; }
	}
</style>
