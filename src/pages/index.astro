---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { Image } from 'astro:assets';
import heroImg from '../assets/deenpic.png';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero-section">
				<div class="top-row animate-in">
					<div class="hero-image-circle">
						<Image src={heroImg} alt="Kitti-Ampon Chia De En" loading="eager" />
					</div>
					<div class="intro-box">
						<h5>Hey there! <br> I'm De En and you've just stumbled across my portfolio! Let me show you around.</h5>
					</div>
				</div>

				<div class="bottom-content">
					<div class="description-text">
						<p class="animate-in delay-1">
							I am an Engineering Science student from Ngee Ann Polytechnic. I aspire to be an engineer that leverages on empathy and human-centered design to develop products that change the way we live for the better!
						</p>
						<a href="/academic&experience" class="btn animate-in delay-1">My Academic Journey and Experience!</a>
						
						<p class="animate-in delay-2">
							I have immersed myself in research and development (R&D) projects since Secondary School and am still going at it! My projects cover a wide range of domains from agriculture to experimental physics. 
						</p>
						<a href="/projects" class="btn animate-in delay-2">Projects that I have worked on!</a>
						
						<p class="animate-in delay-3">
							Beyond my passion for STEM, I am also motivated to serve my community both locally and overseas. I have experience organising volunteering initiatives as well as leading an overseas service learning trip! <br> I believe that as a leader, I am responsible for serving the people who I am leading which makes leadership another form of service to me.
						</p>
						<a href="/sl" class="btn animate-in delay-3">My Service and Leadership Experience!</a>
						
						<p class="animate-in delay-4">
							Feel free to click this button if you are interested in browsing my Achievements and Certificates!
						</p>
						<a href="/achievements" class="btn animate-in delay-4">My Achievements and Certificates!</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
/* --- NEW ANIMATION LOGIC --- */
padding-top: 80px; /* Adjust based on your header's actual height */

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-in {
  opacity: 0; /* Starts invisible */
  animation: fadeInUp 0.5s ease-out forwards;
}

/* Staggering Delays */
.delay-1 { animation-delay: 0s; }
.delay-2 { animation-delay: 0s; }
.delay-3 { animation-delay: 0s; }
.delay-4 { animation-delay: 0s; }

/* --- YOUR EXISTING STYLES --- */

.hero-section {
	display: flex;
	flex-direction: column;
	align-items: center;
	gap: 2rem;
	padding: 2rem;
	max-width: 1000px;
	margin: 0 auto;
}

.hero-image-circle {
  width: 500px;         
  aspect-ratio: 1 / 1;   
  border-radius: 50%;     
  overflow: hidden;       
  border: 4px solid #0056b3; 
}

.hero-image-circle img {
  width: 100%;
  height: 100%;
  object-fit: cover;      
  object-position: center; 
}

.top-row {
  display: flex;
  align-items: center;
  gap: 3rem;
  width: 100%;
}

.bottom-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.description-text {
  background: white;
  padding: 2.5rem;
  margin-top: 1rem;
  border-radius: 12px;
  box-shadow: 0 10px 25px rgba(0,0,0,0.05);
  border-top: 4px solid #0056b3; 
  text-align: justify;
  text-justify: inter-word;
  line-height: 1.6;
}

.btn {
  display: block;      
  width: 100%;         
  max-width: 450px;    
  margin: 1.5rem auto; 
  text-align: center;
  text-decoration: none; 
  color: white;
  font-weight: 600;      
  padding: 1rem;
  background: #0056b3;   
  border-radius: 6px;
  transition: all 0.2s ease-in-out;
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
}

.btn:hover {
  background: #004494;
  transform: translateY(-2px); 
  box-shadow: 0 5px 15px rgba(0,86,179,0.3);
}
</style>
