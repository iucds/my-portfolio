---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Achievements | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="timeline-wrapper">
			<h1 class="section-title">Achievements</h1>

			<div class="stats-banner">
				<div class="stat-box">
					<span class="stat-number">18</span>
					<span class="stat-label">Distinctions</span>
				</div>
				<div class="stat-box">
					<span class="stat-number">10</span>
					<span class="stat-label">Top in Module</span>
				</div>
			</div>

			<div class="timeline-container">
				<div class="scroll-line" id="scroll-line"></div>

				<div class="timeline-item is-visible">
					<div class="circle"></div>
					<div class="content-card">
						<h2 class="qualification">Academic Excellence</h2>
						<p class="duration">Engineering Science @ Ngee Ann Polytechnic</p>
						
						<ul class="achievement-list">
							<li class="highlight">Most Outstanding Performance: Level 2.2, 1.2, 1.1</li>
							<li>3rd Most Outstanding Performance: Level 2.1</li>
							<li class="highlight">Director’s List: All Semesters (2023 - 2025)</li>
							<li>
								<strong>Module Prizes:</strong> 
								Applied Math (1, 2A, 3), Microcontrollers, Physics (1, 2), 
								Analogue Electronics, Electrical & Mechanical Fundamentals, Engineering & Society.
							</li>
						</ul>
					</div>
				</div>

				<div class="timeline-item is-visible">
					<div class="circle"></div>
					<div class="content-card">
						<h2 class="qualification">Scholarships</h2>
						<p class="duration">Academic & Research Merit</p>
						
						<ul class="achievement-list">
							<li class="highlight">A*STAR Science Award (Polytechnic)</li>
							<p class="date-sub">2024 — 2026</p>
							
							<li class="highlight">Ngee Ann Polytechnic Scholarship</li>
							<p class="date-sub">2023 — 2026</p>
						</ul>
					</div>
				</div>

				<div class="timeline-item is-visible">
					<div class="circle"></div>
					<div class="content-card">
						<h2 class="qualification">Major Competitions</h2>
						<p class="duration">International & National Level</p>
						
						<ul class="achievement-list">
							<li class="highlight">National Robotics Competition 2023 — First Place</li>
							<li class="highlight">Global Robotic Games 2023 — First Place</li>
							<li>BusTech Grand Challenge 2025 — 2nd Runner Up</li>
							<li>Young Inventor’s Journal — Gold Award</li>
							<li>Engineering Innovation Challenge — 1st Runner Up</li>
							<li>Applied Science Project Olympiad — Silver Award</li>
						</ul>
						<a href="/projects" class="timeline-btn">Explore Projects</a>
					</div>
				</div>
			</div>
		</main>
		<Footer />

		<script>
			// Grow the blue line based on scroll percentage
			const updateScrollLine = () => {
				const scrollLine = document.getElementById('scroll-line');
				if (scrollLine) {
					const winScroll = window.scrollY;
					const height = document.documentElement.scrollHeight - window.innerHeight;
					const scrolled = (winScroll / height) * 100;
					scrollLine.style.setProperty('--scroll-height', `${scrolled}%`);
				}
			};

			window.addEventListener('scroll', updateScrollLine);
			// Initial call to set position on load
			updateScrollLine();
		</script>
	</body>
</html>

<style>
	.timeline-wrapper {
		max-width: 1000px;
		margin: 0 auto;
		padding: 4rem 1.5rem;
	}

	.section-title {
		text-align: center;
		color: #0056b3;
		margin-bottom: 2rem;
		font-size: 2.5rem;
		font-weight: 700;
	}

	/* Stats Dashboard */
	.stats-banner {
		display: flex;
		justify-content: center;
		gap: 4rem;
		margin-bottom: 5rem;
	}
	.stat-box {
		text-align: center;
	}
	.stat-number {
		display: block;
		font-size: 3rem;
		font-weight: 800;
		color: #0056b3;
		line-height: 1;
	}
	.stat-label {
		color: #666;
		text-transform: uppercase;
		font-size: 0.85rem;
		letter-spacing: 1.5px;
		font-weight: 600;
	}

	/* Timeline Container */
	.timeline-container {
		position: relative;
		padding-left: 60px;
	}

	.scroll-line {
		position: absolute;
		left: 20px;
		top: 0;
		width: 4px;
		height: 100%;
		background: #eee;
		z-index: 0;
	}

	.scroll-line::after {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: var(--scroll-height, 0%);
		background: #0056b3;
		transition: height 0.1s ease-out;
	}

	.timeline-item {
		position: relative;
		margin-bottom: 5rem;
	}

	.circle {
		position: absolute;
		left: -52px; 
		top: 24px; 
		width: 24px;
		height: 24px;
		background: #0056b3;
		border: 4px solid white;
		border-radius: 50%;
		z-index: 2;
		box-shadow: 0 0 0 4px #0056b3;
	}

	/* Content Cards */
	.content-card {
		background: white;
		padding: 2.5rem;
		border-radius: 16px;
		box-shadow: 0 10px 30px rgba(0,0,0,0.06);
		border-top: 5px solid #0056b3;
		transition: transform 0.3s ease;
	}

	.content-card:hover {
		transform: translateY(-5px);
	}

	.qualification {
		font-size: 1.6rem;
		margin: 0 0 0.25rem 0;
		color: #1a1a1a;
	}

	.duration {
		font-style: italic;
		color: #0056b3;
		margin-bottom: 1.5rem;
		font-weight: 500;
	}

	.date-sub {
		font-size: 0.9rem;
		color: #666;
		margin: -0.5rem 0 1rem 1.2rem;
		font-style: italic;
	}

	/* Achievement List */
	.achievement-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.achievement-list li {
		margin-bottom: 0.8rem;
		padding-left: 1.5rem;
		position: relative;
		color: #444;
	}

	.achievement-list li::before {
		content: "•";
		color: #0056b3;
		position: absolute;
		left: 0;
		font-weight: bold;
		font-size: 1.2rem;
	}

	.highlight {
		font-weight: 700;
		color: #000;
	}

	/* Button Styling */
	.timeline-btn {
		display: inline-block;
		margin-top: 1.5rem;
		padding: 0.75rem 1.5rem;
		background: #0056b3;
		color: white !important;
		text-decoration: none;
		border-radius: 6px;
		font-size: 0.95rem;
		font-weight: 600;
		transition: all 0.2s ease;
	}

	.timeline-btn:hover {
		background: #004494;
		box-shadow: 0 4px 12px rgba(0, 86, 179, 0.3);
	}

	/* Mobile Responsiveness */
	@media (max-width: 768px) {
		.timeline-wrapper { padding: 2rem 1rem; }
		.stats-banner { gap: 2rem; flex-direction: column; margin-bottom: 3rem; }
		.timeline-container { padding-left: 40px; }
		.scroll-line { left: 10px; }
		.circle { left: -42px; width: 20px; height: 20px; }
		.qualification { font-size: 1.3rem; }
		.content-card { padding: 1.5rem; }
	}
</style>
