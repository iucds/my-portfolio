---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Achievements">
	<main>
		<section class="content">
			<h1>Achievements & Awards</h1>
			
			<div class="category">
				<h2>🏆 Major Competition Wins</h2>
				<ul>
					<li><strong>2025:</strong> BusTech Grand Challenge (Tertiary Category) — 2nd Runner Up</li>
					<li><strong>2023:</strong> National Robotics Competition (Tertiary Division) — First Place</li>
					<li><strong>2023:</strong> Global Robotic Games (Mobile Robotics IV) — First Place</li>
					<li><strong>2022:</strong> Young Inventor’s Journal — Gold Award</li>
					<li><strong>2020:</strong> Engineering Innovation Challenge — 1st Runner Up</li>
					<li><strong>2020:</strong> Indonesia International Applied Science Project Olympiad — Silver Award</li>
				</ul>
			</div>

			<hr />

			<div class="category">
				<h2>🎓 Academic Excellence</h2>
				
				<h3>2025</h3>
				<p><strong>Most Outstanding Performance for Level 2.2 in Engineering Science</strong></p>
				<p>Director’s List | Module Prizes: Applied Mathematics 3, Microcontroller and Interfacing, Physics 2</p>

				<h3>2024</h3>
				<p><strong>Most Outstanding Performance for Level 1.2 in Engineering Science</strong></p>
				<p>3rd Most Outstanding Performance for Level 2.1 | Director’s List</p>
				<p>Module Prizes: Physics 1, Applied Mathematics 2A, Analogue Electronics</p>

				<h3>2023</h3>
				<p><strong>Most Outstanding Performance for Level 1.1 in Engineering Science</strong></p>
				<p>Director’s List | Module Prizes: Applied Mathematics 1, Electrical Engineering, Engineering and Society, Mechanical Engineering</p>
			</div>

			<hr />

			<div class="category">
				<h2>📜 Certifications</h2>
				<div class="carousel-container">
					<div class="carousel" id="cert-carousel">
						<img src="/certs/nrc.jpg" alt="NRC 2023" />
						<img src="/certs/grg.jpg" alt="Global Robotic Games" />
						<img src="/certs/directors.jpg" alt="Director's List" />
						<img src="/certs/math-olympiad.jpg" alt="SASMO Gold" />
						</div>
					<div class="controls">
						<button id="prev">Back</button>
						<button id="next">Next</button>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	main {
		max-width: 800px;
		margin: 0 auto;
		padding: 2rem;
		line-height: 1.6;
	}
	h1 { font-size: 2.5rem; margin-bottom: 2rem; }
	h2 { color: var(--accent); margin-top: 2rem; border-bottom: 1px solid #eee; padding-bottom: 0.5rem; }
	h3 { margin-top: 1.5rem; margin-bottom: 0.5rem; }
	p { margin: 0.25rem 0; }
	ul { padding-left: 1.2rem; }
	li { margin-bottom: 0.5rem; }
	hr { margin: 3rem 0; border: 0; border-top: 1px solid #eee; }

	/* Simple Carousel Logic */
	.carousel-container {
		margin-top: 1rem;
		position: relative;
	}
	.carousel {
		display: flex;
		overflow-x: auto;
		scroll-snap-type: x mandatory;
		gap: 1rem;
		scrollbar-width: none; /* Hide scrollbar */
	}
	.carousel::-webkit-scrollbar { display: none; }
	.carousel img {
		flex: 0 0 100%; /* Shows one cert at a time */
		scroll-snap-align: start;
		width: 100%;
		border-radius: 8px;
		border: 1px solid #ddd;
	}
	.controls {
		display: flex;
		gap: 1rem;
		margin-top: 1rem;
		justify-content: center;
	}
	button {
		padding: 0.5rem 1rem;
		cursor: pointer;
	}
</style>

<script>
	const carousel = document.getElementById('cert-carousel');
	const next = document.getElementById('next');
	const prev = document.getElementById('prev');

	if (carousel && next && prev) {
		next.onclick = () => {
			if (carousel.scrollLeft + carousel.clientWidth >= carousel.scrollWidth) {
				carousel.scrollTo({ left: 0, behavior: 'smooth' });
			} else {
				carousel.scrollBy({ left: carousel.clientWidth, behavior: 'smooth' });
			}
		};
		prev.onclick = () => {
			if (carousel.scrollLeft <= 0) {
				carousel.scrollTo({ left: carousel.scrollWidth, behavior: 'smooth' });
			} else {
				carousel.scrollBy({ left: -carousel.clientWidth, behavior: 'smooth' });
			}
		};
	}
</script>
