---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="timeline-wrapper">
			<h1 class="section-title">Achievements</h1>

			<div class="stats-banner">
				<div class="stat-box">
					<span class="stat-number">18</span>
					<span class="stat-label">Distinctions</span>
				</div>
				<div class="stat-box">
					<span class="stat-number">10</span>
					<span class="stat-label">Top in Module</span>
				</div>
			</div>

			<div class="timeline-container">
				<div class="scroll-line" id="scroll-line"></div>

				<div class="timeline-item is-visible">
					<div class="circle"></div>
					<div class="content-card">
						<h2 class="qualification">Academic Excellence (2023 - 2025)</h2>
						<p class="duration">Engineering Science @ Ngee Ann Polytechnic</p>
						
						<ul class="achievement-list">
							<li class="highlight">Most Outstanding Performance: Level 2.2, 1.2, 1.1</li>
							<li>3rd Most Outstanding Performance: Level 2.1</li>
							<li class="highlight">Director’s List: All Semesters</li>
							<li><strong>Module Prizes:</strong> Applied Math (1, 2A, 3), Microcontrollers, Physics (1, 2), Analogue Electronics, Electrical & Mechanical Fundamentals, Engineering & Society.</li>
						</ul>
					</div>
				</div>

				<div class="timeline-item is-visible">
					<div class="circle"></div>
					<div class="content-card">
						<h2 class="qualification">Major Competitions</h2>
						<p class="duration">International & National Level</p>
						
						<ul class="achievement-list">
							<li class="highlight">National Robotics Competition 2023 — First Place</li>
							<li class="highlight">Global Robotic Games 2023 — First Place</li>
							<li>BusTech Grand Challenge 2025 — 2nd Runner Up</li>
							<li>Young Inventor’s Journal — Gold Award</li>
							<li>Engineering Innovation Challenge — 1st Runner Up</li>
							<li>Applied Science Project Olympiad — Silver Award</li>
						</ul>
						<a href="/projects" class="timeline-btn">View Project Details</a>
					</div>
				</div>
			</div>
		</main>
		<Footer />

		<script>
			// Logic to make the blue scroll line grow as you scroll
			window.addEventListener('scroll', () => {
				const scrollLine = document.getElementById('scroll-line');
				const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
				const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
				const scrolled = (winScroll / height) * 100;
				if (scrollLine) {
					scrollLine.style.setProperty('--scroll-height', scrolled + '%');
				}
			});
		</script>
	</body>
</html>

<style>
	/* Incorporating your provided styles */
	.timeline-wrapper {
		max-width: 1000px;
		margin: 0 auto;
		padding: 4rem 1.5rem;
	}

	.section-title {
		text-align: center;
		color: #0056b3;
		margin-bottom: 2rem;
		font-size: 2.5rem;
	}

	/* Stats Banner Styling */
	.stats-banner {
		display: flex;
		justify-content: center;
		gap: 3rem;
		margin-bottom: 4rem;
	}
	.stat-box {
		text-align: center;
	}
	.stat-number {
		display: block;
		font-size: 2.5rem;
		font-weight: bold;
		color: #0056b3;
	}
	.stat-label {
		color: #666;
		text-transform: uppercase;
		font-size: 0.8rem;
		letter-spacing: 1px;
	}

	.timeline-container {
		position: relative;
		padding-left: 50px;
	}

	.scroll-line {
		position: absolute;
		left: 20px;
		top: 0;
		width: 4px;
		height: 100%;
		background: #eee;
		z-index: 0;
	}

	.scroll-line::after {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: var(--scroll-height, 0%);
		background: #0056b3;
		transition: height 0.3s ease-out;
	}

	.timeline-item {
		position: relative;
		margin-bottom: 4rem;
		opacity: 1; /* Set to 1 by default so content is visible */
	}

	.circle {
		position: absolute;
		left: -42px; 
		top: 25px; 
		width: 20px;
		height: 20px;
		background: #0056b3; /* Filled by default to match your style */
		border: 4px solid white;
		border-radius: 50%;
		z-index: 2;
		box-shadow: 0 0 0 4px #0056b3;
	}

	.content-card {
		background: white;
		padding: 2.5rem;
		border-radius: 12px;
		box-shadow: 0 10px 25px rgba(0,0,0,0.05);
		border-top: 4px solid #0056b3;
		line-height: 1.6;
	}

	.qualification {
		font-size: 1.5rem;
		margin-bottom: 0.25rem;
		color: #333;
	}

	.duration {
		font-style: italic;
		color: #0056b3;
		margin-bottom: 1.5rem;
	}

	.achievement-list {
		list-style: none;
		padding: 0;
	}

	.achievement-list li {
		margin-bottom: 0.8rem;
		padding-left: 1.2rem;
		position: relative;
	}

	.achievement-list li::before {
		content: "•";
		color: #0056b3;
		position: absolute;
		left: 0;
		font-weight: bold;
	}

	.highlight {
		font-weight: 600;
		color: #111;
	}

	.timeline-btn {
		display: inline-block;
		margin-top: 1.5rem;
		padding: 0.6rem 1.2rem;
		background: #0056b3;
		color: white !important;
		text-decoration: none;
		border-radius: 4px;
		font-size: 0.9rem;
		transition: background 0.2s;
	}

	.timeline-btn:hover {
		background: #004494;
	}

	@media (max-width: 720px) {
		.timeline-container { padding-left: 30px; }
		.scroll-line { left: 10px; }
		.circle { left: -32px; }
		.stats-banner { gap: 1rem; }
	}
</style>
