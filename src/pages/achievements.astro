---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Achievements">
	<main>
		<section class="achievements-container">
			<h1>Achievements & Awards</h1>
			<p class="subtitle">A record of academic excellence and competition success in Engineering Science.</p>

			<div class="award-section">
				<h2 class="section-title">🏆 Competition Highlights</h2>
				
				<div class="award-entry">
					<span class="year">2025</span>
					<div class="details">
						<h3>BusTech Grand Challenge</h3>
						<p>Tertiary Category — 2nd Runner Up</p>
					</div>
				</div>

				<div class="award-entry">
					<span class="year">2023</span>
					<div class="details">
						<h3>National Robotics Competition</h3>
						<p>Tertiary Division — First Place</p>
					</div>
				</div>

				<div class="award-entry">
					<span class="year">2023</span>
					<div class="details">
						<h3>Global Robotic Games</h3>
						<p>Mobile Robotics IV — First Place</p>
					</div>
				</div>

				<div class="award-entry">
					<span class="year">2022</span>
					<div class="details">
						<h3>Young Inventor’s Journal</h3>
						<p>Gold Award</p>
					</div>
				</div>

				<div class="award-entry">
					<span class="year">2020</span>
					<div class="details">
						<h3>Engineering Innovation Challenge</h3>
						<p>1st Runner Up</p>
					</div>
				</div>
			</div>

			<hr />

			<div class="award-section">
				<h2 class="section-title">🎓 Academic Excellence</h2>

				<div class="academic-block">
					<h3>2025</h3>
					<ul>
						<li><strong>Most Outstanding Performance</strong> for Level 2.2 in Engineering Science</li>
						<li><strong>Director’s List</strong></li>
						<li><strong>Module Prizes:</strong> Applied Mathematics 3, Microcontroller and Interfacing, Physics 2</li>
					</ul>
				</div>

				<div class="academic-block">
					<h3>2024</h3>
					<ul>
						<li><strong>Most Outstanding Performance</strong> for Level 1.2 in Engineering Science</li>
						<li><strong>3rd Most Outstanding Performance</strong> for Level 2.1 in Engineering Science</li>
						<li><strong>Director’s List</strong></li>
						<li><strong>Module Prizes:</strong> Physics 1, Applied Mathematics 2A, Analogue Electronics</li>
					</ul>
				</div>

				<div class="academic-block">
					<h3>2023</h3>
					<ul>
						<li><strong>Most Outstanding Performance</strong> for Level 1.1 in Engineering Science</li>
						<li><strong>Director’s List</strong></li>
						<li><strong>Module Prizes:</strong> Applied Mathematics 1, Electrical Engineering Fundamentals, Engineering and Society, Mechanical Engineering Fundamentals</li>
					</ul>
				</div>
			</div>

			<hr />

			<div class="award-section">
				<h2 class="section-title">🏅 Other Notable Awards</h2>
				<ul class="simple-list">
					<li>Indonesia International Applied Science Project Olympiad — Silver Award</li>
					<li>SUTD-SST-NP Big D Camp — Design Excellence Award</li>
					<li>Singapore and Asian Schools Math Olympiad — Gold & Silver Awards</li>
					<li>Australian Mathematics Competition — Distinction</li>
					<li>SST Book Prize — Mathematics & Electronics</li>
				</ul>
			</div>
		</section>
	</main>
</Layout>

<style>
	main {
		max-width: 850px;
		margin: 0 auto;
		padding: 4rem 1.5rem;
		color: #333;
	}

	h1 { font-size: 2.5rem; margin-bottom: 0.5rem; color: #111; }
	.subtitle { color: #666; font-size: 1.1rem; margin-bottom: 3rem; }

	.section-title {
		font-size: 1.5rem;
		margin-bottom: 1.5rem;
		color: var(--accent);
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.award-entry {
		display: flex;
		gap: 2rem;
		margin-bottom: 1.5rem;
		align-items: baseline;
	}

	.year {
		font-weight: bold;
		color: var(--accent);
		min-width: 60px;
	}

	.details h3 { margin: 0; font-size: 1.2rem; }
	.details p { margin: 0.2rem 0; color: #555; }

	.academic-block { margin-bottom: 2rem; }
	.academic-block h3 { border-left: 4px solid var(--accent); padding-left: 1rem; margin-bottom: 1rem; }
	
	ul { padding-left: 1.5rem; }
	li { margin-bottom: 0.5rem; }

	.simple-list li { list-style-type: square; color: #444; }

	hr { margin: 4rem 0; border: 0; border-top: 1px solid #eee; }

	@media (max-width: 600px) {
		.award-entry { flex-direction: column; gap: 0.2rem; }
	}
</style>
