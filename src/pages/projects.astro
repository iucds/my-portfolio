<style>
	.projects-grid {
		display: grid;
		/* DESKTOP: Exactly two equal columns */
		grid-template-columns: 1fr 1fr; 
		gap: 2.5rem;
		width: 100%;
	}

	.projects-hero { 
		text-align: center; 
		margin-bottom: 4rem; 
	}
	
	.projects-hero h1 { 
		color: #0056b3; 
		font-size: 2.5rem; 
	}

	/* --- 3. PROJECT CARD STYLES --- */
	.project-card {
		background: white;
		border-radius: 12px;
		overflow: hidden;
		box-shadow: 0 10px 25px rgba(0,0,0,0.05);
		border-top: 5px solid #0056b3;
		cursor: pointer;
		width: 100%;
		display: flex;
		flex-direction: column;

		/* Fade-up Logic */
		opacity: 0;
		transform: translateY(40px);
		transition: 
			opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1), 
			transform 0.8s cubic-bezier(0.4, 0, 0.2, 1), 
			box-shadow 0.3s ease;
	}

	/* Triggers via Intersection Observer in your JS */
	.project-card.reveal {
		opacity: 1;
		transform: translateY(0);
	}

	.project-card.reveal:hover {
		transform: translateY(-8px);
		box-shadow: 0 15px 35px rgba(0, 86, 179, 0.15);
	}

	.project-image { 
		height: 180px; /* Slightly taller for the wider 2-column layout */
		padding: 1rem; 
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.tag { 
		background: #0056b3; 
		color: white; 
		padding: 0.3rem 0.8rem; 
		border-radius: 4px; 
		font-size: 0.75rem; 
		font-weight: bold; 
	}

	.project-content { 
		padding: 1.5rem; 
		text-align: justify; 
		line-height: 1.6; 
		flex-grow: 1;
	}

	.tech-label { 
		font-family: monospace; 
		color: #0056b3; 
		font-weight: bold; 
		margin-bottom: 0.5rem; 
		font-size: 0.9rem;
	}

	/* --- 4. MOBILE RESPONSIVENESS (STRICT 1-COLUMN) --- */
	@media (max-width: 850px) {
		main {
			margin-top: 100px; /* Extra clearance for mobile headers */
			padding: 1.5rem 1rem;
		}

		.projects-grid {
			/* MOBILE: Switch to a single vertical stack */
			grid-template-columns: 1fr; 
			gap: 2rem;
		}

		.projects-hero h1 {
			font-size: 1.8rem;
		}

		.project-content {
			text-align: left; /* Justified text looks better left-aligned on small screens */
		}

		dialog {
			width: 95% !important;
		}
	}

	/* --- 5. MODAL / DIALOG STYLES --- */
	dialog {
		border: none;
		border-radius: 16px;
		padding: 0;
		width: 90%;
		max-width: 650px;
		box-shadow: 0 25px 50px rgba(0,0,0,0.25);
		border-top: 8px solid #0056b3;
	}

	dialog::backdrop {
		background: rgba(0, 0, 0, 0.5);
		backdrop-filter: blur(4px);
	}

	.modal-header { 
		display: flex; 
		justify-content: space-between; 
		align-items: center; 
		padding: 1.5rem 2rem; 
		background: #f8f9fa; 
		border-bottom: 1px solid #eee; 
	}

	.modal-body { 
		padding: 2rem; 
		text-align: justify; 
		line-height: 1.7; 
	}

	.close-btn { 
		background: none; 
		border: none; 
		font-size: 2rem; 
		cursor: pointer; 
		color: #999; 
	}

	.btn-project { 
		display: block; 
		background: #0056b3; 
		color: white; 
		text-align: center; 
		text-decoration: none; 
		padding: 0.8rem; 
		border-radius: 6px; 
		font-weight: bold; 
		margin-top: 1.5rem; 
	}
    .carousel-container {
        width: 100%;
        margin-bottom: 2rem;
        position: relative;
    }

    .carousel-track {
        display: flex;
        overflow-x: auto; /* Enables horizontal scrolling */
        scroll-snap-type: x mandatory; /* The "lock" mechanism */
        scroll-behavior: smooth;
        -webkit-overflow-scrolling: touch; /* Smooth momentum on iPhone */
        gap: 1.5rem;
        padding-bottom: 1rem;
    }

    /* Hide scrollbar for a cleaner look */
    .carousel-track::-webkit-scrollbar {
        display: none;
    }

    .carousel-slide {
        flex: 0 0 100%; /* Each slide takes 100% of the modal width */
        scroll-snap-align: start; /* Where the slide "snaps" to */
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .carousel-slide img {
        width: 100%;
        height: 300px; /* Fixed height for consistency */
        object-fit: cover;
        border-radius: 12px;
        border: 1px solid #eee;
    }

    .caption {
        font-size: 0.85rem;
        color: #666;
        margin-top: 0.75rem;
        font-style: italic;
    }

    .scroll-hint {
        text-align: right;
        font-size: 0.7rem;
        color: #0056b3;
        font-weight: bold;
        text-transform: uppercase;
        margin-top: -0.5rem;
    }

    /* Tablet/Desktop: Show 1.5 slides to hint there is more content */
    @media (min-width: 768px) {
        .carousel-slide {
            flex: 0 0 85%; 
        }
    }
</style>
