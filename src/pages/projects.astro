---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

// --- 1. CARD THUMBNAILS ---
import fyp0 from '../assets/fyp-0.jpg';
import asiot0 from '../assets/asiot-0.jpg';
import cvdl0 from '../assets/cvdl-0.jpg';
import ifs0 from '../assets/ifs-0.jpg';
import bustech0 from '../assets/bustech-0.jpg';
import nrc0 from '../assets/nrc-0.jpg';
import ysap0 from '../assets/ysap-0.jpg';
import balloonsat0 from '../assets/balloonsat-0.jpg';

// --- 2. CAROUSEL IMAGES (3 PER PROJECT) ---
import fyp1 from '../assets/fyp-1.jpg'; import fyp2 from '../assets/fyp-2.jpg'; import fyp3 from '../assets/fyp-3.jpg';
import asiot1 from '../assets/asiot-1.jpg'; import asiot2 from '../assets/asiot-2.jpg'; import asiot3 from '../assets/asiot-3.jpg';
import cvdl1 from '../assets/cvdl-1.jpg'; import cvdl2 from '../assets/cvdl-2.jpg'; import cvdl3 from '../assets/cvdl-3.jpg';
import ifs1 from '../assets/ifs-1.jpg'; import ifs2 from '../assets/ifs-2.jpg'; import ifs3 from '../assets/ifs-3.jpg';
import bustech1 from '../assets/bustech-1.jpg'; import bustech2 from '../assets/bustech-2.jpg'; import bustech3 from '../assets/bustech-3.jpg';
import nrc1 from '../assets/nrc-1.jpg'; import nrc2 from '../assets/nrc-2.jpg'; import nrc3 from '../assets/nrc-3.jpg';
import ysap1 from '../assets/ysap-1.jpg'; import ysap2 from '../assets/ysap-2.jpg'; import ysap3 from '../assets/ysap-3.jpg';
import balloonsat1 from '../assets/balloonsat-1.jpg'; import balloonsat2 from '../assets/balloonsat-2.jpg'; import balloonsat3 from '../assets/balloonsat-3.jpg';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="projects-hero">
				<h1>STEM Projects & Research</h1>
				<p>Click on the card to find out more about the project. You can also swipe to see more pictures!</p>
			</section>

			<div class="projects-grid">
				<article class="project-card" onclick="document.getElementById('modal-fyp').showModal()">
					<div class="project-image" style={`background-image: url(${fyp0.src});`}>
						<span class="tag">Experimental Physics</span>
						<p class="tech-label">C++ • PIO • UDP</p>
					</div>
					<div class="project-content"><h3>Ion Beam DAQ</h3><p class="short-desc">Digitalisation of DAQ using RP2350.</p></div>
				</article>

				<article class="project-card" onclick="document.getElementById('modal-asiot').showModal()">
					<div class="project-image" style={`background-image: url(${asiot0.src});`}>
						<span class="tag">Robotics</span>
						<p class="tech-label">ROS • Python</p>
					</div>
					<div class="project-content"><h3>Autonomous Robot</h3><p class="short-desc">ROS1 to ROS2 migration for future-proofing.</p></div>
				</article>

				<article class="project-card" onclick="document.getElementById('modal-cvdl').showModal()">
					<div class="project-image" style={`background-image: url(${cvdl0.src});`}>
						<span class="tag">AI</span>
						<p class="tech-label">CV • Deep Learning</p>
					</div>
					<div class="project-content"><h3>Fall Detection</h3><p class="short-desc">Pose estimation for elderly safety.</p></div>
				</article>

				<article class="project-card" onclick="document.getElementById('modal-ifs').showModal()">
					<div class="project-image" style={`background-image: url(${ifs0.src});`}>
						<span class="tag">Agriculture</span>
						<p class="tech-label">Arduino • Sustainability</p>
					</div>
					<div class="project-content"><h3>Indoor Farming System</h3><p class="short-desc">Automated urban agriculture solution.</p></div>
				</article>

				<article class="project-card" onclick="document.getElementById('modal-bustech').showModal()">
					<div class="project-image" style={`background-image: url(${bustech0.src});`}>
						<span class="tag">Transport</span>
						<p class="tech-label">C++ • Hardware</p>
					</div>
					<div class="project-content"><h3>Bus Charging Port</h3><p class="short-desc">Hotswappable charging interface design.</p></div>
				</article>

				<article class="project-card" onclick="document.getElementById('modal-nrc').showModal()">
					<div class="project-image" style={`background-image: url(${nrc0.src});`}>
						<span class="tag">Robotics</span>
						<p class="tech-label">EV3 • Sensors • Robot Intelligence</p>
					</div>
					<div class="project-content"><h3>NRC Robotics</h3><p class="short-desc">National Robotics Competition Entry.</p></div>
				</article>

				<article class="project-card" onclick="document.getElementById('modal-ysap').showModal()">
					<div class="project-image" style={`background-image: url(${ysap0.src});`}>
						<span class="tag">Health</span>
						<p class="tech-label">Electronics • Service</p>
					</div>
					<div class="project-content"><h3>Dementicon</h3><p class="short-desc">Psychomotor Augmented Reality Games to fight against Dementia in Elderly.</p></div>
				</article>

				<article class="project-card" onclick="document.getElementById('modal-balloonsat').showModal()">
					<div class="project-image" style={`background-image: url(${balloonsat0.src});`}>
						<span class="tag">Space Tech</span>
						<p class="tech-label">Telemetry • Sensors</p>
					</div>
					<div class="project-content"><h3>Balloon Satellite</h3><p class="short-desc">Cube satellite to collect atmospheric data.</p></div>
				</article>
			</div>

			<dialog id="modal-fyp" class="project-modal">
				<div class="modal-header"><h2>Ion Beam Analysis DAQ</h2><button class="close-btn">&times;</button></div>
				<div class="modal-body">
					<div class="carousel-container"><div class="carousel-track">
						<div class="carousel-slide"><Image src={fyp1} alt="" width={800} height={450} /></div>
						<div class="carousel-slide"><Image src={fyp2} alt="" width={800} height={450} /></div>
						<div class="carousel-slide"><Image src={fyp3} alt="" width={800} height={450} /></div>
					</div></div>
					<p>A data acquisition (DAQ) system uses hardware and software to measure, convert and record physical phenomena into digital data that a computer can analyse. It is essential in experimental setups which require accurate and high-speed data collection for scientific or industrial applications. I worked with my partner to build DAQ prototype that interfaces with the FAST ComTec 7072T ADC and a device that simulated its operation to digitalise the DAQ modules. Our device is being used by the scientists at the Centre for Ion Beam analysis for applications such as Alpha Spectroscopy and Material Imaging.</p>
				</div>
			</dialog>

			<dialog id="modal-asiot" class="project-modal">
				<div class="modal-header"><h2>Autonomous Navigation</h2><button class="close-btn">&times;</button></div>
				<div class="modal-body">
					<div class="carousel-container"><div class="carousel-track">
						<div class="carousel-slide"><Image src={asiot1} alt="" width={800} height={450} /></div>
						<div class="carousel-slide"><Image src={asiot2} alt="" width={800} height={450} /></div>
						<div class="carousel-slide"><Image src={asiot3} alt="" width={800} height={450} /></div>
					</div></div>
					<p>This project focuses the migration of the MuSHR robot’s Jetson Nano codebase from ROS 1 to ROS 2 on Ubuntu 20.04. The process involved troubleshooting issues, including VESC-related problems, while converting and adapting essential modules and portions of code for ROS 2 compatibility. Efforts focused on enabling as many major nodes as possible to restore core functionality. Experimental validation demonstrated successful proof-of-concept operation, achieving reliable motion control of the robot on the ROS 2 Ubuntu 20.04 platform. </p>
				</div>
			</dialog>

			<dialog id="modal-cvdl" class="project-modal">
				<div class="modal-header"><h2>Fall Detection</h2><button class="close-btn">&times;</button></div>
				<div class="modal-body">
					<div class="carousel-container"><div class="carousel-track">
						<div class="carousel-slide"><Image src={cvdl1} alt="" width={800} height={450} /></div>
						<div class="carousel-slide"><Image src={cvdl2} alt="" width={800} height={450} /></div>
						<div class="carousel-slide"><Image src={cvdl3} alt="" width={800} height={450} /></div>
					</div></div>
					<p>As Singapore becomes an aging society, most households have elderly in them. However, the main risk that these elderly face is the risk of falling and the consequences. To combat this, most households with elderly have surveillance cameras to monitor these elderly to ensure their safety. To support this, this project aims to implement fall detection by torso tracking with YOLO pose estimation so that they can be used to process surveillance footage and alert the user if the elderly or anyone else in the house has fallen.</p>
				</div>
			</dialog>
			<dialog id="modal-ifs" class="project-modal">
				<div class="modal-header"><h2>Indoor Farming System</h2><button class="close-btn">&times;</button></div>
				<div class="modal-body">
					<div class="carousel-container"><div class="carousel-track">
						<div class="carousel-slide"><Image src={ifs1} alt="" width={800} height={450} /></div>
						<div class="carousel-slide"><Image src={ifs2} alt="" width={800} height={450} /></div>
						<div class="carousel-slide"><Image src={ifs3} alt="" width={800} height={450} /></div>
					</div></div>
					<p>The Engineering Innovation Challenge, or EIC for short, is a competition where students are to think of
						a solution to a problem relating to energy innovation. The theme for EIC 2020 was “To explore or make
						innovative improvements on the application of ionising radiation in the area of food security”. My team
						decided to solve this problem by developing a prototype, called the “Indoor Farming System”, which
						utilises ionising radiation to accelerate the growth of plants. It also has an automated watering system
						and environmental control so that the plants can grow in optimal conditions. My team was able to come in 2nd despite this being our first engineering competition.</p>
				</div>
			</dialog>
			<dialog id="modal-bustech" class="project-modal">
				<div class="modal-header"><h2>Bus Charging Port</h2><button class="close-btn">&times;</button></div>
				<div class="modal-body">
					<div class="carousel-container"><div class="carousel-track">
						<div class="carousel-slide"><Image src={bustech1} alt="" width={800} height={450} /></div>
						<div class="carousel-slide"><Image src={bustech2} alt="" width={800} height={450} /></div>
						<div class="carousel-slide"><Image src={bustech3} alt="" width={800} height={450} /></div>
					</div></div>
					<p> I participated in this competition to solve a real world problem which was posed by SBS to address the problem of USB charging port on the bus. Our solution was to make a hotswappable USB port which can be tracked using IoT with a live dashboard to make it more convenient for the engineer to conduct maintenance checks. My team was able to come in 3rd in this competition.</p>
				</div>
			</dialog>
			<dialog id="modal-nrc" class="project-modal">
				<div class="modal-header"><h2>NRC Robotics</h2><button class="close-btn">&times;</button></div>
				<div class="modal-body">
					<div class="carousel-container"><div class="carousel-track">
						<div class="carousel-slide"><Image src={nrc1} alt="" width={800} height={450} /></div>
						<div class="carousel-slide"><Image src={nrc2} alt="" width={800} height={450} /></div>
						<div class="carousel-slide"><Image src={nrc3} alt="" width={800} height={450} /></div>
					</div></div>
					<p> I participated in this competition with a group of friends to build a LEGO robot which move around solar panels in a simulated playfield. We were able to be the Champions for 2 competitions from our submission.</p>
				</div>
			</dialog>
			<dialog id="modal-ysap" class="project-modal">
				<div class="modal-header"><h2>Dementicon</h2><button class="close-btn">&times;</button></div>
				<div class="modal-body">
					<div class="carousel-container"><div class="carousel-track">
						<div class="carousel-slide"><Image src={ysap1} alt="" width={800} height={450} /></div>
						<div class="carousel-slide"><Image src={ysap2} alt="" width={800} height={450} /></div>
						<div class="carousel-slide"><Image src={ysap3} alt="" width={800} height={450} /></div>
					</div></div>
					<p> The Youth Science Ambassador
						Programme, or YSAP for short, is a
						programme in which students are trained
						and mentored to work on a community
						project. My team decided to work on a
						community project that targeted the
						elderly, and how to prevent dementia
						from affecting them. In the end, my team
						developed a prototype, named “Project
						Dementi-Con”, a game console that
						would help to engage the elderly in
						augmented reality games that would
						engage them both physically and also
						stimulate their brain, helping them stay
						active and not develop dementia.</p>
				</div>
			</dialog>
			<dialog id="modal-nrc" class="project-modal">
				<div class="modal-header"><h2>NRC Robotics</h2><button class="close-btn">&times;</button></div>
				<div class="modal-body">
					<div class="carousel-container"><div class="carousel-track">
						<div class="carousel-slide"><Image src={nrc1} alt="" width={800} height={450} /></div>
						<div class="carousel-slide"><Image src={nrc2} alt="" width={800} height={450} /></div>
						<div class="carousel-slide"><Image src={nrc3} alt="" width={800} height={450} /></div>
					</div></div>
					<p> I participated in this competition with a group of friends to build a LEGO robot which move around solar panels in a simulated playfield. We were able to be the Champions for 2 competitions from our submission.</p>
				</div>
			</dialog>
			</main>
		<Footer />

		<script>
			document.querySelectorAll('dialog').forEach(dialog => {
				dialog.querySelector('.close-btn')?.addEventListener('click', () => (dialog as HTMLDialogElement).close());
				dialog.addEventListener('click', (e) => { if (e.target === dialog) (dialog as HTMLDialogElement).close(); });
			});

			const observer = new IntersectionObserver((entries) => {
				entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('reveal'); });
			}, { threshold: 0.1 });
			document.querySelectorAll('.project-card').forEach(card => observer.observe(card));
		</script>
	</body>
</html>

<style>
	main { 
		max-width: 1100px; 
		margin-left: auto; 
		margin-right: auto; 
		width: 100%; 
	}

	/* Hero Section matches your portfolio's typography */
	.projects-hero { 
		text-align: center; 
		margin-bottom: 4rem; 
	}

	.projects-hero h1 {
		color: #0056b3;
		font-size: 2.8rem; /* Scaled to match Academic titles */
		font-weight: 800;
		letter-spacing: -0.02em;
	}

	/* --- GRID & CARDS --- */
	.projects-grid { 
		display: grid; 
		grid-template-columns: 1fr 1fr; 
		gap: 2.5rem; 
		width: 100%; 
	}

	.project-card { 
		background: white; 
		border-radius: 12px; 
		overflow: hidden; 
		box-shadow: 0 10px 25px rgba(0,0,0,0.05); 
		border-top: 5px solid #0056b3; 
		cursor: pointer; 
		display: flex; 
		flex-direction: column; 
		opacity: 0; 
		transform: translateY(40px); 
		transition: opacity 0.8s ease, transform 0.8s ease, box-shadow 0.3s ease; 
	}

	.project-card.reveal { opacity: 1; transform: translateY(0); }
	.project-card:hover { transform: translateY(-8px); box-shadow: 0 15px 35px rgba(0, 86, 179, 0.15); }
	
	.project-image { 
		height: 200px; 
		padding: 1.2rem; 
		display: flex; 
		flex-direction: column; 
		align-items: flex-start; 
		justify-content: flex-start; 
		gap: 0.5rem; 
		background-size: contain; 
		background-repeat: no-repeat;
		background-position: center;
		background-color: #f8f9fa;
		position: relative; 
	}
	
	.tag { background: #0056b3; color: white; padding: 0.3rem 0.8rem; border-radius: 4px; font-size: 0.75rem; font-weight: bold; z-index: 2; }
	.tech-label { font-family: monospace; color: #0056b3; background: rgba(255, 255, 255, 0.9); padding: 0.2rem 0.5rem; border-radius: 4px; font-weight: bold; font-size: 0.8rem; margin: 0; z-index: 2; }
	.project-content { padding: 1.5rem; flex-grow: 1; }

	/* --- CAROUSEL & MODALS --- */
	.carousel-container { width: 100%; margin-bottom: 2rem; }
	.carousel-track { display: flex; overflow-x: auto; scroll-snap-type: x mandatory; scroll-behavior: smooth; gap: 1rem; }
	.carousel-track::-webkit-scrollbar { display: none; }
	.carousel-slide { flex: 0 0 100%; scroll-snap-align: start; background: #f0f0f0; border-radius: 12px; overflow: hidden;}
	.carousel-slide img { width: 100%; height: 400px; object-fit: contain; }
	
	dialog { border: none; border-radius: 16px; padding: 0; width: 90%; max-width: 800px; border-top: 8px solid #0056b3; }
	dialog::backdrop { background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(4px); }
	.modal-header { display: flex; justify-content: space-between; padding: 1.5rem 2rem; background: #f8f9fa; }
	.modal-body { padding: 2rem; line-height: 1.7; }
	.close-btn { background: none; border: none; font-size: 2rem; cursor: pointer; color: #999; }
	
	@media (max-width: 850px) { 
		main { margin-top: 100px; }
		.projects-grid { grid-template-columns: 1fr; } 
		.carousel-slide { flex: 0 0 90%; } 
	}
</style>
