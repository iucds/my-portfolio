---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="projects-hero">
				<h1>My Service and Leadership Experience!</h1>
				<p>Click on a card to find out more about each experience.</p>
			</section>

			<div class="projects-grid">
				<article class="project-card" onclick="document.getElementById('modal-pico').showModal()">
