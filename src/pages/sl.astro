---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

// --- 1. CARD THUMBNAILS (Check these filenames in src/assets/) ---
import yepV0 from '../assets/yep-vietnam-0.jpg';
import yepT0 from '../assets/yep-thailand-0.jpg';
import esac0 from '../assets/esac-0.jpg';
import wos0 from '../assets/wos-0.jpg';
import wh0 from '../assets/wh-0.jpg';
import kk0 from '../assets/kk-0.jpg';
import irr0 from '../assets/irr-0.jpg';

// --- 2. MODAL ASSETS (Carousels for V, T, WOS, KK) ---
import v1 from '../assets/yep-v1.jpg'; import v2 from '../assets/yep-v2.jpg'; import v3 from '../assets/yep-v3.jpg';
import t1 from '../assets/yep-t1.jpg'; import t2 from '../assets/yep-t2.jpg'; import t3 from '../assets/yep-t3.jpg';
import w1 from '../assets/wos-1.jpg'; import w2 from '../assets/wos-2.jpg'; import w3 from '../assets/wos-3.jpg';
import kk1 from '../assets/kk-1.jpg'; import kk2 from '../assets/kk-2.jpg'; import kk3 from '../assets/kk-3.jpg';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Service & Leadership | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero-section">
				<h1>Service & Leadership</h1>
				<p>Technical logic meets social impact. A documentation of my community contributions and leadership roles.</p>
			</section>

			<div class="projects-grid">
				<article class="project-card" onclick="document.getElementById('modal-vietnam').showModal()">
					<div class="project-image" style={`background-image: url(${yepV0.src});`}>
						<span class="tag">International Service</span>
						<p class="tech-label">Ben Tre • Community Building</p>
					</div>
					<div class="project-content"><h3>YEP: Vietnam</h3><p class="short-desc">Service-learning in Ben Tre.</p></div>
				</article>

				<article class="project-card" onclick="document.getElementById('modal-thailand').showModal()">
					<div class="project-image" style={`background-image: url(${yepT0.src});`}>
						<span class="tag">Leadership</span>
						<p class="tech-label">Udon Thani • Student Leader</p>
					</div>
					<div class="project-content"><h3>YEP: Thailand</h3><p class="short-desc">Leading a team in Udon Thani.</p></div>
				</article>

				<article class="project-card" onclick="document.getElementById('modal-esac').showModal()">
					<div class="project-image" style={`background-image: url(${esac0.src});`}>
						<span class="tag">Academic Club</span>
						<p class="tech-label">ESAC • Logistics Head</p>
					</div>
					<div class="project-content"><h3>ESAC Logistics Head</h3><p class="short-desc">Managing academic club operations.</p></div>
				</article>

				<article class="project-card" onclick="document.getElementById('modal-wos').showModal()">
					<div class="project-image" style={`background-image: url(${wos0.src});`}>
						<span class="tag">Chairperson</span>
						<p class="tech-label">WOS • Leadership</p>
					</div>
					<div class="project-content"><h3>Wings of Solidarity</h3><p class="short-desc">Spearheading advocacy initiatives.</p></div>
				</article>

				<article class="project-card" onclick="document.getElementById('modal-wh').showModal()">
					<div class="project-image" style={`background-image: url(${wh0.src});`}>
						<span class="tag">Volunteering</span>
						<p class="tech-label">Willing Hearts</p>
					</div>
					<div class="project-content"><h3>Volunteer: Willing Hearts</h3><p class="short-desc">Supporting soup kitchen operations.</p></div>
				</article>

				<article class="project-card" onclick="document.getElementById('modal-kk').showModal()">
					<div class="project-image" style={`background-image: url(${kk0.src});`}>
						<span class="tag">Volunteering</span>
						<p class="tech-label">Kampung Kakis</p>
					</div>
					<div class="project-content"><h3>Volunteer: Kampung Kakis</h3><p class="short-desc">Localized senior support outreach.</p></div>
				</article>

				<article class="project-card" onclick="document.getElementById('modal-irr').showModal()">
					<div class="project-image" style={`background-image: url(${irr0.src});`}>
						<span class="tag">Volunteering</span>
						<p class="tech-label">IRR • Migrant Workers</p>
					</div>
					<div class="project-content"><h3>Volunteer: ItsRainingRaincoats</h3><p class="short-desc">Supporting migrant worker welfare.</p></div>
				</article>
			</div>

			<dialog id="modal-esac" class="project-modal">
				<div class="modal-header"><h2>ESAC Logistics Head</h2><button class="close-btn">&times;</button></div>
				<div class="modal-body">
					<div class="single-image-container"><Image src={esac0} alt="" width={800} height={450} /></div>
					<p>Operational details for the Engineering Science Academic Club...</p>
				</div>
			</dialog>

			<dialog id="modal-wh" class="project-modal">
				<div class="modal-header"><h2>Willing Hearts</h2><button class="close-btn">&times;</button></div>
				<div class="modal-body">
					<div class="single-image-container"><Image src={wh0} alt="" width={800} height={450} /></div>
					<p>Kitchen operations and distribution details...</p>
				</div>
			</dialog>

			<dialog id="modal-kk" class="project-modal">
				<div class="modal-header"><h2>Kampung Kakis</h2><button class="close-btn">&times;</button></div>
				<div class="modal-body">
					<div class="carousel-container"><div class="carousel-track">
						<div class="carousel-slide"><Image src={kk1} alt="" width={800} height={450} /></div>
						<div class="carousel-slide"><Image src={kk2} alt="" width={800} height={450} /></div>
						<div class="carousel-slide"><Image src={kk3} alt="" width={800} height={450} /></div>
					</div></div>
					<p>Community outreach reflections...</p>
				</div>
			</dialog>

			<dialog id="modal-irr" class="project-modal">
				<div class="modal-header"><h2>ItsRainingRaincoats</h2><button class="close-btn">&times;</button></div>
				<div class="modal-body">
					<div class="single-image-container"><Image src={irr0} alt="" width={800} height={450} /></div>
					<p>Migrant worker support initiatives...</p>
				</div>
			</dialog>
            
            </main>
		<Footer />

		<script>
			document.querySelectorAll('dialog').forEach(dialog => {
				dialog.querySelector('.close-btn')?.addEventListener('click', () => (dialog as HTMLDialogElement).close());
				dialog.addEventListener('click', (e) => { if (e.target === dialog) (dialog as HTMLDialogElement).close(); });
			});
			const observer = new IntersectionObserver((entries) => {
				entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add('reveal'); });
			}, { threshold: 0.1 });
			document.querySelectorAll('.project-card').forEach(card => observer.observe(card));
		</script>
	</body>
</html>

<style>
	/* Use the matching header styles from the previous turn */
	main { margin-top: 120px; max-width: 1100px; margin-left: auto; margin-right: auto; padding: 2rem; width: 100%; }
	.hero-section { text-align: center; margin-bottom: 4rem; }
	.hero-section h1 { color: #0056b3; font-size: 2.8rem; font-weight: 800; }
	.projects-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; width: 100%; }
	.project-card { background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 10px 25px rgba(0,0,0,0.05); border-top: 5px solid #0056b3; cursor: pointer; display: flex; flex-direction: column; opacity: 0; transform: translateY(40px); transition: 0.8s ease; }
	.project-card.reveal { opacity: 1; transform: translateY(0); }
	.project-card:hover { transform: translateY(-8px); box-shadow: 0 1
