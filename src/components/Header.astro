---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header id="main-header">
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/academic">Academic</HeaderLink>
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/sl">Service Learning</HeaderLink>
		</div>
	</nav>
</header>

<script>
	let lastScroll = 0;
	const header = document.getElementById('main-header');

	window.addEventListener('scroll', () => {
		const currentScroll = window.pageYOffset;

		// 1. If at the very top, make sure header is visible
		if (currentScroll <= 0) {
			header?.classList.remove('scroll-down');
			return;
		}

		// 2. If scrolling down, hide the header
		if (currentScroll > lastScroll && !header?.classList.contains('scroll-down')) {
			header?.classList.add('scroll-down');
		} 
		// 3. If scrolling up, show the header
		else if (currentScroll < lastScroll && header?.classList.contains('scroll-down')) {
			header?.classList.remove('scroll-down');
		}

		lastScroll = currentScroll;
	});
</script>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		position: fixed; /* Necessary for the scroll effect */
		top: 0;
		width: 100%;
		z-index: 1000;
		transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
	}

	/* This class is toggled by the script above */
	header.scroll-down {
		transform: translateY(-100%);
	}

	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1200px;
		margin: 0 auto;
	}

	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}

	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}

	/* Mobile Optimizations */
	@media (max-width: 720px) {
		nav {
			padding: 0.5em;
		}
		.internal-links {
			display: flex;
			gap: 0.5em;
		}
		nav a {
			padding: 0.5em;
			font-size: 0.85rem;
		}
	}
</style>
