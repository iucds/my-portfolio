---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header id="main-header">
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">About</HeaderLink>
			<HeaderLink href="/academic&experience">Academics</HeaderLink>
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/sl">Leadership</HeaderLink>
			<HeaderLink href="/achievements">Achievements</HeaderLink>
		</div>
		<div class="social-links">
            <a href="https://github.com/withastro/astro" target="_blank">
				<span class="sr-only">Go to Astro's GitHub repo</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path></svg>
			</a>
		</div>
	</nav>
</header>

<script>
    // Hide Header on Scroll Logic
	let lastScroll = 0;
	const header = document.getElementById('main-header');

	window.addEventListener('scroll', () => {
		const currentScroll = window.pageYOffset;
		if (currentScroll <= 0) {
			header.style.transform = 'translateY(0)';
			return;
		}
		if (currentScroll > lastScroll) {
			header.style.transform = 'translateY(-100%)'; // Hide on scroll down
		} else {
			header.style.transform = 'translateY(0)'; // Show on scroll up
		}
		lastScroll = currentScroll;
	});
</script>

<style>
	header {
		position: fixed; /* Changed from sticky to fixed for better mobile control */
		top: 0;
		width: 100%;
		z-index: 1000;
		margin: 0;
		padding: 0 1em;
		background: rgba(255, 255, 255, 0.9);
		backdrop-filter: blur(8px);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
		transition: transform 0.4s ease; /* Animation for the hide/show */
	}
    
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1200px;
		margin: 0 auto;
	}

	.internal-links {
		display: flex;
	}

	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
		font-size: 0.95rem;
	}

	nav a.active {
		border-bottom-color: var(--accent);
	}

	/* --- MOBILE OPTIMIZATIONS --- */
	@media (max-width: 720px) {
		nav {
			flex-direction: column; /* Stack Title and Links */
			padding: 0.5em 0;
		}

		h2 {
			margin-bottom: 0.25em;
		}

		.internal-links {
			width: 100%;
			overflow-x: auto; /* Let links scroll sideways if they don't fit */
			white-space: nowrap; /* Keep links on one line */
			justify-content: flex-start;
			-webkit-overflow-scrolling: touch;
			padding-bottom: 4px; /* Space for the scrollbar */
		}

		nav a {
			padding: 0.8em 0.6em;
			font-size: 0.8rem; /* Smaller font for mobile */
		}

		.social-links {
			display: none;
		}
	}
</style>
